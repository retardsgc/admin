{
  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://backend-ghv0.onrender.com/api"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-ghv0.onrender.com/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "https://backend-ghv0.onrender.com/images/:path*"
    },
    {
      "source": "/((?!_next|assets|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
